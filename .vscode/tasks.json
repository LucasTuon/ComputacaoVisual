{
  "tasks": [
    {
      "label": "Compilar exemplo (MinGW: make)",
      "type": "shell",
      "command": "make",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}/src/${input:EscolherExemplo}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
      }
    },
    {
      "label": "Compilar e rodar exemplo (MinGW: make -> main.exe)",
      "type": "shell",
      "command": "make; if ($?) { .\\main.exe }",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}/src/${input:EscolherExemplo}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
    },
    {
      "label": "Limpar exemplo (MinGW: make clean)",
      "type": "shell",
      "command": "make clean",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}/src/${input:EscolherExemplo}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "test",
      },
    },
    {
      "label": "Limpar todos os exemplos (MinGW: make clean)",
      "type": "shell",
      "command": "Get-ChildItem -Path src -Directory | ForEach-Object { Write-Host \"Limpando $($_.Name)...\"; make -C $_.FullName clean }",
      "args": [],
      "options": {
        "shell": {
          "executable": "powershell.exe",
          "args": [
            "-NoProfile",
            "-Command"
          ]
        }
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "EscolherExemplo",
      "type": "pickString",
      "description": "Qual exemplo você quer {compilar|rodar|limpar}?",
      "options": [
        "01-hello",
        "02-renderer",
        "03-image",
        "04-invert_image",
        "05-filter_image",
        "06-primitives"
      ],
    }      
  ],
  "version": "2.0.0"
}